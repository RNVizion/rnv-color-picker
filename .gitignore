# =====================================================================
# RNV Color Picker — .gitignore
# =====================================================================

# ---- Python bytecode / cache ----------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so

# ---- Virtual environments -------------------------------------------
venv/
.venv/
env/
.env/
ENV/

# ---- Distribution / packaging ---------------------------------------
build/
dist/
*.egg-info/
*.egg
.eggs/
sdist/
wheels/
share/python-wheels/
MANIFEST

# ---- PyInstaller artifacts ------------------------------------------
*.manifest
*.spec.bak
build_pyinstaller/

# ---- Test & coverage artifacts --------------------------------------
.pytest_cache/
.tox/
.nox/
.coverage
.coverage.*
htmlcov/
coverage.xml
*.cover
.hypothesis/

# Combined coverage data files generated by run_tests.py
.coverage.unittest
.coverage.pytest

# Plain-text coverage snapshots
coverage_report.txt

# ---- Type checker / linter caches -----------------------------------
.mypy_cache/
.dmypy.json
.pyre/
.pytype/
.ruff_cache/

# ---- Environment / secrets ------------------------------------------
.env
.env.local
*.local.toml
secrets.json

# ---- IDE / editor ---------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.spyderproject
.spyproject
.ropeproject

# ---- Visual Studio (you ship a .pyproj, but its build artifacts are local) ----
.vs/
*.suo
*.user
*.userosscache
*.sln.docstates
bin/
obj/
*.VC.db
*.opendb

# ---- OS-generated files ---------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# ---- Application-specific -------------------------------------------
# Sandbox / scratch files
*.sandbox-bak
*_sandbox.py

# Local log files (the app writes to user data dir by default,
# but if it falls back to cwd these may appear)
color_picker.log
color_picker_errors.log
*.log

# Local PyInstaller staging (if you build executables locally)
*.exe
RNV-Color-Picker.exe

# Jupyter / notebook scratch (if you ever script with notebooks)
.ipynb_checkpoints/

# Local session files (the app writes these to user data dir by default,
# but ad-hoc test sessions in cwd shouldn't be tracked)
*.cpksession
autosave_*.json

# Local settings file (the app writes to %AppData%\ColorPicker by default;
# anchored to root so settings.json deeper in the tree isn't ignored)
/settings.json

# Local databases (future-proofing — none ship today, but cheap insurance)
*.db
*.sqlite
*.sqlite3

# ---- Docs build (if you add Sphinx later) ---------------------------
docs/_build/
docs/api/
